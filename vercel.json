{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "functions": {
    "api/handler.ts": {
      "includeFiles": "providers.json"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net https://*.clerk.accounts.dev https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.clerk.accounts.dev https://api.clerk.com; img-src 'self' data: https://img.clerk.com; worker-src 'self' blob:; frame-src 'self' https://*.clerk.accounts.dev https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://*.clerk.accounts.dev"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/health", "destination": "/api/handler?__route=/health" },
    {
      "source": "/api/accounts",
      "destination": "/api/handler?__route=/api/accounts"
    },
    {
      "source": "/api/auth/config",
      "destination": "/api/handler?__route=/api/auth/config"
    },
    {
      "source": "/api/user/router",
      "destination": "/api/handler?__route=/api/user/router"
    },
    { "source": "/api/me", "destination": "/api/handler?__route=/api/me" },
    {
      "source": "/api/prompts",
      "destination": "/api/handler?__route=/api/prompts"
    },
    {
      "source": "/api/prompts/:prompt",
      "destination": "/api/handler?__route=/api/prompts/:prompt"
    },
    {
      "source": "/api/public/prompts/:prompt",
      "destination": "/api/handler?__route=/api/public/prompts/:prompt"
    },
    {
      "source": "/api/public/prompts/:prompt/runs",
      "destination": "/api/handler?__route=/api/public/prompts/:prompt/runs"
    },
    {
      "source": "/api/providers/:provider",
      "destination": "/api/handler?__route=/api/providers/:provider"
    },
    {
      "source": "/v1/models",
      "destination": "/api/handler?__route=/v1/models"
    },
    {
      "source": "/v1/chat/completions",
      "destination": "/api/handler?__route=/v1/chat/completions"
    },
    {
      "source": "/p/:prompt",
      "destination": "/prompt.html?id=:prompt"
    }
  ]
}
